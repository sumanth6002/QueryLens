# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
JWT_EXPIRY_HOURS=24

# MySQL (application metadata database)
# Leave unset to use SQLite automatically in development (backend/instance/querylens.db)
# DATABASE_URL=mysql+pymysql://root:your-password@localhost:3306/querylens

# Set to true to log SQL statements in development
SQLALCHEMY_ECHO=false

# Maximum rows returned by the SQL editor for SELECT-like statements
SQL_MAX_RESULT_ROWS=500

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
